# Miden Indexer Configuration Example
# Copy this file to .env and fill in the values

# PostgreSQL connection string
POSTGRES_URL=postgresql://username:password@localhost:5432/midenscan

# Miden Node RPC URL
RPC_URL=https://rpc.testnet.miden.io

# Network ID (mainnet, testnet, devnet)
# Note: uses lowercase for consistency
MIDEN_NETWORK=testnet

# Port for the health and metrics HTTP server
HTTP_PORT=8080

# Logging level (error, warn, info, debug, trace)
RUST_LOG=info
